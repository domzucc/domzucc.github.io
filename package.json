{
  "name": "domzucc.github.io",
  "version": "0.0.1",
  "description": "Personal Website Based on JSON Resume",
  "author": "Domagoj Zuccon",
  "repository": {
    "type": "git",
    "url": "https://github.com/domzucc/domzucc.github.io"
  },
  "scripts": {
    "preview": "preview",
    "deploy": "cp public/* .",
    "previewEnglish": "resume serve -r resume/english.json -p 420 english",
