    "previewSkeleton": "resume serve -r resume/skeleton.json -p 422 english"
  },
  "bin": {
    "resume": "./node_modules/.bin/resume"
  },
  "license": "MIT",
  "dependencies": {
    "handlebars": "4.1.2",
    "resume-cli": "1.1.2"
  }
}
